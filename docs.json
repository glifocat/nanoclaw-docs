{
  "$schema": "https://mintlify.com/docs.json",
  "name": "NanoClaw",
  "theme": "mint",
  "logo": {
    "light": "/images/nanoclaw-logotype-dark.svg",
    "dark": "/images/nanoclaw-logotype-dark.svg",
    "href": "https://nanoclaw.dev"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#2DD4BF",
    "light": "#5EEAD4",
    "dark": "#14B8A6"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/qwibitai/nanoclaw"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/qwibitai/nanoclaw",
      "discord": "https://discord.gg/VDdww8qS42",
      "x": "https://x.com/Gavriel_Cohen",
      "youtube": "https://www.youtube.com/@NanoClaw",
      "website": "https://nanoclaw.dev"
    },
    "links": [
      {
        "header": "Legal",
        "items": [
          { "label": "MIT License", "href": "https://github.com/qwibitai/nanoclaw/blob/main/LICENSE" }
        ]
      }
    ]
  },
  "seo": {
    "indexing": "navigable"
  },
  "search": {
    "prompt": "Search NanoClaw docs..."
  },
  "metadata": {
    "og:site_name": "NanoClaw Docs",
    "og:image": "/images/social-preview.jpg",
    "twitter:site": "@Gavriel_Cohen",
    "timestamp": true
  },
  "feedback": {
    "thumbsRating": true
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "anchors": [
    { "anchor": "GitHub", "href": "https://github.com/qwibitai/nanoclaw", "icon": "github" },
    { "anchor": "Discord", "href": "https://discord.gg/VDdww8qS42", "icon": "discord" }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Core Concepts",
            "icon": "lightbulb",
            "pages": [
              "concepts/architecture",
              "concepts/security",
              "concepts/containers",
              "concepts/groups",
              "concepts/tasks"
            ]
          },
          {
            "group": "Features",
            "icon": "sparkles",
            "pages": [
              "features/messaging",
              "features/scheduled-tasks",
              "features/agent-swarms",
              "features/customization",
              "features/web-access"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": [
              "integrations/overview",
              "integrations/skills-system",
              "integrations/whatsapp",
              "integrations/telegram",
              "integrations/discord",
              "integrations/slack",
              "integrations/gmail",
              "integrations/ollama"
            ]
          },
          {
            "group": "Advanced",
            "icon": "gear",
            "pages": [
              "advanced/security-model",
              "advanced/container-runtime",
              "advanced/docker-sandboxes",
              "advanced/ipc-system",
              "advanced/remote-control",
              "advanced/troubleshooting",
              "advanced/contributing"
            ]
          },
          {
            "group": "Changelog",
            "icon": "clock-rotate-left",
            "pages": [
              "changelog/index",
              "changelog/docs-updates"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api/overview",
              "api/configuration",
              "api/message-routing",
              "api/group-management",
              "api/task-scheduling"
            ]
          },
          {
            "group": "Skills Development",
            "pages": [
              "api/skills/creating-skills",
              "api/skills/skill-structure",
              "api/skills/examples"
            ]
          }
        ]
      }
    ]
  }
}
